# ─────────────────────────────────────────────────────────────
# KIRA 백엔드 환경변수 예시 (.env.example)
#   실제 값은 .env 에 채운다. 이 파일에는 절대 실값/시크릿을 넣지 않는다.
#   config.py(Settings) + os.getenv 사용처 기준. 값 없으면 앱이 기동 실패하는 항목은 [필수].
# ─────────────────────────────────────────────────────────────

# ── 데이터베이스 (PostgreSQL / PostGIS / pgvector) ── [필수]
POSTGRES_USER=kira
POSTGRES_PASSWORD=change-me
POSTGRES_DB=kira
# SQLAlchemy asyncpg DSN. 도커 컴포즈에선 host=db, 로컬 직접이면 host=localhost.
DATABASE_URL=postgresql+asyncpg://kira:change-me@db:5432/kira

# ── Redis (ARQ 큐) ── [필수]
REDIS_URL=redis://redis:6379/0

# ── 이벤트 버스 (PostgreSQL LISTEN/NOTIFY 채널명) ── [필수]
KIRA_EVENT_CHANNEL=kira_events

# ── JWT 인증 ──
SECRET_KEY=change-me-to-a-long-random-secret   # [필수] 길고 무작위한 값
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── 메일 (AWS SES) ── [신규]
#   MAIL_ENABLED=false 또는 MAIL_FROM 비어있으면 실제 발송 없이 no-op(로그만) → SES
#   발신 identity 검증 전/로컬/CI 안전. 발송 켜려면 아래 둘을 채운다.
#   자격증명은 코드/.env 가 아니라 boto3 기본 체인(EC2 IAM Role / 로컬 ~/.aws)에서 해석.
AWS_REGION=ap-northeast-2
MAIL_ENABLED=false
MAIL_FROM=                                       # 예: no-reply@your-verified-domain.com (SES 검증 주소)

# ── 프론트/링크 조립 기준 URL ──
FRONTEND_BASE_URL=http://localhost:3000          # 초대/가입 URL(?supplierId=) 조립 기준
BASE_URL=http://localhost:8000                   # 서버 자기참조 URL(있으면 사용)
