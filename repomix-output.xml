<file path=".github/workflows/ci.yml">
name: CI (PR 검증 — 경고 모드)

# PR 열림/업데이트 시 실행. main push 배포(deploy.yml)와 분리.
on:
  pull_request:
    branches: [main, develop]

permissions:
  contents: read
  pull-requests: write   # PR 코멘트 게시

jobs:
  ci:
    runs-on: ubuntu-latest
    steps:
      - name: 체크아웃 (diff 위해 전체 히스토리)
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Python 셋업
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: 의존성 설치 (lint/test 도구)
        run: |
          python -m pip install --upgrade pip
          pip install ruff httpx pytest

      # ── ① 코드리뷰 자동화: 정적 분석 + KIRA 고질병 정합성 ──
      - name: ruff (정적 분석, 경고만)
        run: ruff check backend || true   # 경고 모드 — 실패해도 진행

      - name: KIRA 정합성 체크
        run: python3 ci/check_conventions.py   # STRICT 미설정 → exit 0

      # ── ② 테스트 자동화: 스택 띄우고 스모크 + 기능 e2e ──
      - name: CI용 .env 생성 (더미값 + 시크릿)
        run: |
          # CI는 임시 테스트 DB이므로 DB 비번 등은 더미로 충분.
          # 진짜 비밀(외부 연동)만 GitHub Secrets에서 주입한다.
          cat > .env << EOF
          POSTGRES_USER=kira_admin
          POSTGRES_PASSWORD=ci_dummy_password
          POSTGRES_DB=kira_db
          DATABASE_URL=postgresql+asyncpg://kira_admin:ci_dummy_password@db:5432/kira_db
          REDIS_URL=redis://redis:6379/0
          KIRA_EVENT_CHANNEL=kira_events
          SECRET_KEY=${{ secrets.CI_SECRET_KEY || 'ci_dummy_secret_key_not_for_prod' }}
          ALLOWED_ORIGINS=http://localhost:3000
          AWS_REGION=ap-northeast-2
          EOF
          echo ".env 생성 완료 (CI 더미값)"

      - name: docker compose 기동
        run: |
          docker compose up -d --build
          echo "헬스 대기..."
          for i in $(seq 1 30); do
            if curl -sf http://localhost/health >/dev/null; then echo "up"; break; fi
            sleep 5
          done

      - name: 스모크 + 기능 e2e 테스트
        env:
          BASE_URL: http://localhost
        run: |
          pytest ci/test_smoke.py ci/test_e2e.py -v \
            --junitxml=ci/pytest-results.xml || true   # 경고 모드

      # ── ③ 데이터 분석: 메트릭 리포트 생성 ──
      - name: 메트릭 리포트 생성
        env:
          BASE_REF: origin/${{ github.base_ref }}
        run: python3 ci/metrics_report.py

      - name: PR 코멘트 게시
        if: github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const body = fs.readFileSync('ci/report.md', 'utf8');
            // 기존 봇 코멘트 있으면 갱신, 없으면 신규
            const { data: comments } = await github.rest.issues.listComments({
              owner: context.repo.owner, repo: context.repo.repo,
              issue_number: context.issue.number,
            });
            const marker = '## 📊 KIRA CI 리포트';
            const prev = comments.find(c => c.body.startsWith(marker));
            if (prev) {
              await github.rest.issues.updateComment({
                owner: context.repo.owner, repo: context.repo.repo,
                comment_id: prev.id, body,
              });
            } else {
              await github.rest.issues.createComment({
                owner: context.repo.owner, repo: context.repo.repo,
                issue_number: context.issue.number, body,
              });
            }

      - name: 리포트 아티팩트 업로드
        uses: actions/upload-artifact@v4
        with:
          name: ci-report
          path: |
            ci/report.md
            ci/pytest-results.xml
          if-no-files-found: warn

      - name: 스택 정리
        if: always()
        run: docker compose down -v || true
</file>

<file path=".github/workflows/deploy.yml">
name: Deploy to EC2 (SSM)

# main 브랜치에 push되면 자동 배포
on:
  push:
    branches:
      - main

# 동시 배포 방지 (이전 실행 취소)
concurrency:
  group: deploy-ec2
  cancel-in-progress: true

# OIDC 토큰 발급에 필요한 권한
permissions:
  id-token: write      # OIDC 토큰 요청
  contents: read       # 저장소 체크아웃

env:
  AWS_REGION: ap-northeast-2
  INSTANCE_ID: ${{ secrets.EC2_INSTANCE_ID }}

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      # 1) OIDC로 AWS 임시 자격 획득 (키 없음)
      - name: AWS 자격 획득 (OIDC)
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: ${{ secrets.AWS_DEPLOY_ROLE_ARN }}
          aws-region: ${{ env.AWS_REGION }}

      # 2) SSM으로 EC2에 배포 명령 전송하고 완료까지 대기
      - name: SSM 배포 실행
        run: |
          set -euo pipefail

          echo "배포 명령 전송 중..."
          COMMAND_ID=$(aws ssm send-command \
            --region "$AWS_REGION" \
            --instance-ids "$INSTANCE_ID" \
            --document-name "AWS-RunShellScript" \
            --comment "GitHub Actions deploy $GITHUB_SHA" \
            --parameters '{"commands":[
              "set -e",
              "export HOME=/root",
              "git config --global --add safe.directory /home/ubuntu/kira",
              "cd /home/ubuntu/kira",
              "git fetch origin main",
              "git reset --hard origin/main",
              "docker compose up -d --build",
              "docker exec kira-nginx nginx -s reload",
              "docker image prune -f",
              "docker compose ps"
            ],"executionTimeout":["1200"]}' \
            --query "Command.CommandId" \
            --output text)

          echo "Command ID: $COMMAND_ID"
          echo "EC2에서 실행 완료 대기 중..."

          # 완료까지 폴링 (최대 20분)
          aws ssm wait command-executed \
            --region "$AWS_REGION" \
            --command-id "$COMMAND_ID" \
            --instance-id "$INSTANCE_ID" || true

          # 결과 조회
          STATUS=$(aws ssm get-command-invocation \
            --region "$AWS_REGION" \
            --command-id "$COMMAND_ID" \
            --instance-id "$INSTANCE_ID" \
            --query "Status" --output text)

          echo "===== 표준 출력 ====="
          aws ssm get-command-invocation \
            --region "$AWS_REGION" \
            --command-id "$COMMAND_ID" \
            --instance-id "$INSTANCE_ID" \
            --query "StandardOutputContent" --output text

          echo "===== 표준 에러 ====="
          aws ssm get-command-invocation \
            --region "$AWS_REGION" \
            --command-id "$COMMAND_ID" \
            --instance-id "$INSTANCE_ID" \
            --query "StandardErrorContent" --output text

          echo "최종 상태: $STATUS"
          if [ "$STATUS" != "Success" ]; then
            echo "❌ 배포 실패"
            exit 1
          fi
          echo "✅ 배포 성공"
</file>

