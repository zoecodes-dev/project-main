async def create_data_request_endpoint(
    req: DataRequestCreateRequest,
    db: AsyncSession = Depends(get_db),
    current_user: CurrentUser = Depends(get_current_user),  # [REVERT-NON-SUPPLIER] 이 줄 제거
):
