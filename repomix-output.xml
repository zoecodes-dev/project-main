services:
  # Layer 1: 공급망 데이터 백본 (PostgreSQL + PostGIS + pgvector)
  db:
    build:
      context: .
      dockerfile: docker/db.Dockerfile
    container_name: kira-postgres
    networks:
      - project_net
    env_file:
      - ./.env
    # ports 제거: 외부 노출 안 함. 컨테이너 내부 통신(app→db:5432)만 사용.
    # EC2에서 직접 DB 보려면 SSH 터널 사용.
    volumes:
      - kira_pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER:-kira_admin} -d $${POSTGRES_DB:-kira_db}"]
      interval: 5s
      timeout: 5s
      retries: 5
    restart: always

  # Async Workflow Queue용 Redis (ARQ)
  redis:
    build:
      context: .
      dockerfile: docker/redis.Dockerfile
    container_name: kira-redis
    networks:
      - project_net
    # ports 제거: 외부 노출 안 함. 내부 통신만.
    volumes:
      - kira_redisdata:/data
    healthcheck:
      test: ["CMD-SHELL", "redis-cli ping | grep PONG || exit 1"]
      interval: 5s
      timeout: 5s
      retries: 10
    restart: always

  # Layer 2: KIRA 에이전트 통합 백엔드 (FastAPI)
  app:
    build:
      context: .
      dockerfile: docker/app.Dockerfile
    container_name: kira-backend
    networks:
      - project_net
    env_file:
      - ./.env
    environment:
      - REDIS_URL=redis://redis:6379/0
      - DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
      # CORS .env의 ALLOWED_ORIGINS를 그대로 전달(없으면 config 기본값).
      - ALLOWED_ORIGINS=${ALLOWED_ORIGINS:-http://localhost:3000}
    # ports 제거: 외부 노출 안 함. nginx가 내부에서 app:8000으로 전달.
    # volumes 제거: 이미지 안의 코드를 그대로 사용 (CI/CD 대비, 운영 정석).
    # 부팅 시: 규제 임베딩 자동 시드(멱등) → uvicorn 기동.
    #   스키마 DDL은 docker/01_schema.sql(빈 볼륨 최초 init)로 일원화 — alembic 마이그레이션 미사용.
    #   regulation.embeddings는 pending 규제만 임베딩(멱등, 이미 indexed면 즉시 스킵·재계산 X).
    #   app 컨테이너 1개에서만 실행되므로 경합 없음(워커는 arq라 미실행).
    command: ["sh", "-c", "python -m backend.domains.regulation.embeddings && uvicorn backend.main:app --host 0.0.0.0 --port 8000 --workers 2"]
    expose:
      - "8000"
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    restart: always

  # ─────────────────────────────────────────────────────────────
  # Layer 2: ARQ 워커들 (Queue 컨슈머) — app과 동일 이미지, command만 다름
  #
  # 큐 계약(queue.py QUEUE_NAMES)은 6종. 워커도 큐당 1개 구조로 맞춘다.
  # 모듈이 실제 존재하는 3개만 활성, 나머지 3개는 다음주 모듈 생성 후 주석 해제.
  #   - dead_letter_queue: 워커 없음 (실패 작업 보관용 — 운영자가 수동 처리)
  #
  # 공통 설정은 아래 앵커(worker-base)로 한 번만 정의하고 각 워커가 재사용.
  # ─────────────────────────────────────────────────────────────

  # document_parse_queue 워커 (문서 파싱 — 은진 Data Gateway)
  worker-parse:
    build: &worker-build
      context: .
      dockerfile: docker/app.Dockerfile
    networks:
      - project_net
    env_file:
      - ./.env
    environment: &worker-env
      - REDIS_URL=redis://redis:6379/0
      - DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
    depends_on: &worker-deps
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    restart: always
    container_name: kira-worker-parse
    command: ["arq", "backend.workers.document_parse_worker.WorkerSettings"]

  # verification_queue 워커 (룰 검증 — E)
  worker-verification:
    build: *worker-build
    networks:
      - project_net
    env_file:
      - ./.env
    environment: *worker-env
    depends_on: *worker-deps
    restart: always
    container_name: kira-worker-verification
    command: ["arq", "backend.workers.verification_worker.WorkerSettings"]

  # hitl_queue 워커
  worker-hitl:
    build: *worker-build
    networks:
      - project_net
    env_file:
      - ./.env
    environment: *worker-env
    depends_on: *worker-deps
    restart: always
    container_name: kira-worker-hitl
    command: ["arq", "backend.workers.hitl_worker.WorkerSettings"]

  # batch_pipeline_queue worker
  worker-pipeline:
    build: *worker-build
    networks:
      - project_net
    env_file:
      - ./.env
    environment: *worker-env
    depends_on: *worker-deps
    restart: always
    container_name: kira-worker-pipeline
    command: ["arq", "backend.workers.pipeline_worker.WorkerSettings"]

  # notification_queue 워커
  worker-notification:
    build: *worker-build
    networks:
      - project_net
    env_file:
      - ./.env
    environment: *worker-env
    depends_on: *worker-deps
    restart: always
    container_name: kira-worker-notification
    command: ["arq", "backend.workers.notification_worker.WorkerSettings"]

  worker-submission:
    build: *worker-build
    networks:
      - project_net
    env_file:
      - ./.env
    environment: *worker-env
    depends_on: *worker-deps
    restart: always
    container_name: kira-worker-submission
    command: ["arq", "backend.workers.submission_worker.WorkerSettings"]


  # Layer 0: Nginx 리버스 프록시 (정문 — gzip 압축 + app 전달)
  nginx:
    image: nginx:1.27-alpine
    container_name: kira-nginx
    networks:
      - project_net
    ports:
      - "80:80"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      - app
    restart: always

volumes:
  kira_pgdata:
    name: kira_pgdata
  kira_redisdata:
    name: kira_redisdata

networks:
  project_net:
    driver: bridge
